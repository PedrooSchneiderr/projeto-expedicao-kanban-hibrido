{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "FRONTEND/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/login", "destination": "/api/index.py" },
    { "source": "/signup", "destination": "/api/index.py" },
    { "source": "/orders", "destination": "/api/index.py" },
    { "source": "/orders/(.*)", "destination": "/api/index.py" },
    { "source": "/upload", "destination": "/api/index.py" },
    { "source": "/admin/(.*)", "destination": "/api/index.py" },
    { "source": "/users", "destination": "/api/index.py" },
    { "source": "/chat", "destination": "/api/index.py" },
    { "source": "/ws", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/FRONTEND/$1" }
  ]
}
